# 应用
APP_NAME=LiteratureDrivenResearchAgent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/research_agent
# 过渡期开关：是否允许应用启动时兜底执行 create_all + schema_compat。
# 建议新环境保持 true，待 Alembic 流程完全稳定后再考虑关闭。
RUNTIME_SCHEMA_BOOTSTRAP=true

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=research-agent

# LLM
LLM_PROVIDER=deepseek
OPENAI_API_KEY=your_openai_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# 文献 API
OPENALEX_API_KEY=your_openalex_key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
CROSSREF_MAILTO=your_email@example.com

# OCR：扫描版 PDF 解析。若 tesseract 不在 PATH 中，可填写完整 exe 路径。
TESSERACT_CMD=

# JWT
JWT_SECRET_KEY=your_jwt_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
